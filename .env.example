# =============================================================================
# KSP Crime Intelligence Chatbot — environment template
# Copy this file to ".env" and fill every value. Missing or empty variables
# will crash the FastAPI server on startup (see backend/config/settings.py).
# Never commit your real .env — it stays in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# Catalyst project identity
# -----------------------------------------------------------------------------
# Numeric project id from Catalyst console.
CATALYST_PROJECT_ID=your_catalyst_project_id

# Numeric organization id. Sent as the "CATALYST-ORG" header on every
# Catalyst API call (LLM, NoSQL, Cache, Stratus, Zia, SmartBrowz).
CATALYST_ORG_ID=your_catalyst_org_id

# OAuth access token used as "Authorization: Bearer <token>" on every Catalyst
# call. Short-lived — refresh with the snippet at the bottom of this file.
CATALYST_API_TOKEN=your_catalyst_api_token

# Base URL for the Catalyst region you're hosted in.
#   India:  https://api.catalyst.zoho.in
#   US:     https://api.catalyst.zoho.com
#   EU:     https://api.catalyst.zoho.eu
CATALYST_BASE_URL=https://api.catalyst.zoho.in


# -----------------------------------------------------------------------------
# QuickML — LLM serving
# -----------------------------------------------------------------------------
# Full chat endpoint. Pattern: {CATALYST_BASE_URL}/quickml/v2/project/{CATALYST_PROJECT_ID}/llm/chat
QUICKML_LLM_URL=https://api.catalyst.zoho.in/quickml/v2/project/your_catalyst_project_id/llm/chat

# Model identifiers exposed by Catalyst QuickML.
# IMPORTANT: these are the model strings Catalyst expects, not generic names.
MODEL_SQL=crm-di-qwen_coder_7b-it
MODEL_ANSWER=crm-di-qwen_text_14b-fp8-it
MODEL_VISION=qwen2.5-7b-vl


# -----------------------------------------------------------------------------
# Database — Catalyst Data Store (MySQL-compatible)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ksp_crime_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password


# -----------------------------------------------------------------------------
# Catalyst NoSQL — conversation history storage
# -----------------------------------------------------------------------------
# Pattern: {CATALYST_BASE_URL}/baas/v1/project/{CATALYST_PROJECT_ID}/nosql
NOSQL_BASE_URL=https://api.catalyst.zoho.in/baas/v1/project/your_catalyst_project_id/nosql


# -----------------------------------------------------------------------------
# Catalyst Cache — schema + result caching
# -----------------------------------------------------------------------------
# Pattern: {CATALYST_BASE_URL}/baas/v1/project/{CATALYST_PROJECT_ID}/cache
CACHE_BASE_URL=https://api.catalyst.zoho.in/baas/v1/project/your_catalyst_project_id/cache


# -----------------------------------------------------------------------------
# Catalyst Stratus — evidence media (images, audio, video) object store
# -----------------------------------------------------------------------------
# Pattern: {CATALYST_BASE_URL}/baas/v1/project/{CATALYST_PROJECT_ID}/folder
STRATUS_BASE_URL=https://api.catalyst.zoho.in/baas/v1/project/your_catalyst_project_id/folder


# -----------------------------------------------------------------------------
# Zia Services — voice + translation
# -----------------------------------------------------------------------------
# Pattern: {CATALYST_BASE_URL}/baas/v1/project/{CATALYST_PROJECT_ID}/ml/zia/...
ZIA_STT_URL=https://api.catalyst.zoho.in/baas/v1/project/your_catalyst_project_id/ml/zia/speech/transcribe
ZIA_TTS_URL=https://api.catalyst.zoho.in/baas/v1/project/your_catalyst_project_id/ml/zia/speech/synthesize
ZIA_TRANSLATE_URL=https://api.catalyst.zoho.in/baas/v1/project/your_catalyst_project_id/ml/zia/translate


# -----------------------------------------------------------------------------
# SmartBrowz — headless browser / PDF export
# -----------------------------------------------------------------------------
# Pattern: {CATALYST_BASE_URL}/baas/v1/project/{CATALYST_PROJECT_ID}/smartbrowz
SMARTBROWZ_URL=https://api.catalyst.zoho.in/baas/v1/project/your_catalyst_project_id/smartbrowz


# -----------------------------------------------------------------------------
# App configuration
# -----------------------------------------------------------------------------
# "development" or "production". Reported by /health.
APP_ENV=development

# JWT signing key used by backend/auth/simple_auth.py. Generate a fresh
# 32+ character random string per environment. NEVER reuse across environments.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=replace_me_with_a_32_plus_char_random_string

# Comma-separated origins permitted by FastAPI CORS. Local Vite dev defaults
# to port 5173. Never use "*" in production.
ALLOWED_ORIGINS=http://localhost:5173


# =============================================================================
# Refreshing CATALYST_API_TOKEN (optional reference)
# -----------------------------------------------------------------------------
# Catalyst access tokens expire after ~1 hour. Use your refresh token + Zoho
# OAuth client credentials to mint a new one. Keep these secrets out of git.
#
#   curl -X POST "https://accounts.zoho.in/oauth/v2/token" \
#     -d "grant_type=refresh_token" \
#     -d "client_id=YOUR_CLIENT_ID" \
#     -d "client_secret=YOUR_CLIENT_SECRET" \
#     -d "refresh_token=YOUR_REFRESH_TOKEN"
#
# The response's "access_token" field becomes the new CATALYST_API_TOKEN.
# =============================================================================
